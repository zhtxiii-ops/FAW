import random
from typing import Any, Dict

class random_select_and_extract(Skill):
    def __init__(self):
        self.name = "random_select_and_extract"
        self.description = "从新闻列表中随机选择一条新闻，并提取其标题和URL"
    
    async def execute(self, params: Dict[str, Any]) -> Dict[str, Any]:
        try:
            # 验证输入参数
            if "news_hits" not in params:
                return {"error": "缺少必要参数 'news_hits'"}
            
            news_hits = params["news_hits"]
            
            if not isinstance(news_hits, list):
                return {"error": "'news_hits' 参数必须是列表类型"}
            
            if len(news_hits) == 0:
                return {"error": "新闻列表为空"}
            
            # 随机选择一条新闻
            selected_news = random.choice(news_hits)
            
            # 提取标题和URL
            if not isinstance(selected_news, dict):
                return {"error": "新闻条目必须是字典类型"}
            
            title = selected_news.get("title", "")
            url = selected_news.get("url", "")
            
            # 验证必要字段
            if not title or not url:
                return {"error": "选择的新闻缺少标题或URL"}
            
            return {
                "selected_news": {
                    "title": title,
                    "url": url
                },
                "total_count": len(news_hits)
            }
            
        except KeyError as e:
            return {"error": f"数据格式错误: 缺少键 {str(e)}"}
        except Exception as e:
            return {"error": f"处理过程中发生错误: {str(e)}"}
